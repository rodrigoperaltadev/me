      "html": "\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\" data-kid=\"0\">\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"1\">\n<style data-kid=\"2\">\n    @import url('https://fonts.googleapis.com/css2?family=Geist+Mono:wght@100..900&family=Inter:wght@100..900&display=swap');\n\n    :root {\n        --bg: #010B13;\n        --surface: #0a1622;\n        --card: #141f2b;\n        --accent: #00E5FF;\n        --text-primary: #FFFFFF;\n        --text-secondary: #94A3B8;\n        --border: rgba(255, 255, 255, 0.08);\n        --glow: rgba(0, 229, 255, 0.2);\n    }\n\n    [data-theme=\"light\"] {\n        --bg: #F8FAFC;\n        --surface: #FFFFFF;\n        --card: #F1F5F9;\n        --accent: #0EA5E9;\n        --text-primary: #0F172A;\n        --text-secondary: #475569;\n        --border: rgba(0, 0, 0, 0.05);\n        --glow: rgba(14, 165, 233, 0.2);\n    }\n\n    body {\n        background-color: var(--bg);\n        color: var(--text-primary);\n        font-family: 'Inter', sans-serif;\n        transition: background-color 0.4s ease, color 0.4s ease;\n        -webkit-font-smoothing: antialiased;\n    }\n\n    .font-mono { font-family: 'Geist Mono', monospace; }\n\n    /* Glassmorphism */\n    .glass {\n        background: rgba(255, 255, 255, 0.03);\n        backdrop-filter: blur(12px);\n        -webkit-backdrop-filter: blur(12px);\n        border: 1px solid var(--border);\n    }\n\n    [data-theme=\"light\"] .glass {\n        background: rgba(0, 0, 0, 0.03);\n    }\n\n    /* Marquee Animation */\n    @keyframes marquee {\n        0% { transform: translateX(0); }\n        100% { transform: translateX(-50%); }\n    }\n    .animate-marquee {\n        display: flex;\n        width: max-content;\n        animation: marquee 40s linear infinite;\n    }\n    .animate-marquee-reverse {\n        animation: marquee 40s linear infinite reverse;\n    }\n\n    /* Custom Scrollbar */\n    ::-webkit-scrollbar { width: 8px; }\n    ::-webkit-scrollbar-track { background: var(--bg); }\n    ::-webkit-scrollbar-thumb {\n        background: var(--card);\n        border-radius: 10px;\n    }\n    ::-webkit-scrollbar-thumb:hover { background: var(--accent); }\n\n    /* Noise Background */\n    .noise-bg::before {\n        content: \"\";\n        position: absolute;\n        top: 0; left: 0; width: 100%; height: 100%;\n        background-image: url('https://grainy-gradients.vercel.app/noise.svg');\n        filter: contrast(150%) brightness(100%);\n        opacity: 0.05;\n        pointer-events: none;\n        z-index: 1;\n    }\n\n    /* Neon Glow */\n    .neon-glow {\n        box-shadow: 0 0 15px var(--glow);\n    }\n</style>\n\n<div id=\"root-container\" class=\"noise-bg overflow-x-clip\" data-kid=\"3\">\n    \n    <nav class=\"fixed top-0 left-0 w-full z-50 glass border-b border-white/5 transition-all duration-300\" id=\"navbar\" data-kid=\"4\">\n        <div class=\"max-w-7xl mx-auto px-6 h-20 flex items-center justify-between\" data-kid=\"5\">\n            <div class=\"flex items-center gap-2\" data-kid=\"6\">\n                <div class=\"w-10 h-10 bg-[var(--accent)] text-[var(--bg)] font-bold flex items-center justify-center rounded-lg text-xl font-inter\" data-kid=\"7\">RP</div>\n            </div>\n            \n            <div class=\"hidden md:flex items-center gap-8 text-sm font-medium\" data-kid=\"8\">\n                <a href=\"#about\" class=\"hover:text-[var(--accent)] transition-colors\" data-kid=\"9\">About</a>\n                <a href=\"#experience\" class=\"hover:text-[var(--accent)] transition-colors\" data-kid=\"10\">Experience</a>\n                <a href=\"#tech\" class=\"hover:text-[var(--accent)] transition-colors\" data-kid=\"11\">Skills</a>\n                <a href=\"#contact\" class=\"hover:text-[var(--accent)] transition-colors\" data-kid=\"12\">Contact</a>\n            </div>\n\n            <div class=\"flex items-center gap-4\" data-kid=\"13\">\n                <button id=\"lang-toggle\" class=\"px-3 py-1 rounded-md border border-white/10 text-xs font-bold hover:bg-white/5 transition-colors\" data-kid=\"14\">EN | ES</button>\n                <button id=\"theme-toggle\" class=\"w-10 h-10 flex items-center justify-center rounded-full border border-white/10 hover:bg-white/5 transition-colors\" data-kid=\"15\">\n                    <i class=\"fas fa-moon text-sm\" id=\"theme-icon\" data-kid=\"16\"></i>\n                </button>\n            </div>\n        </div>\n    </nav>\n\n    \n    <section class=\"min-h-screen flex items-center justify-center relative pt-20 px-6 overflow-hidden\" id=\"hero\" data-kid=\"17\">\n        \n        <div id=\"cursor-glow\" class=\"absolute pointer-events-none z-0 w-[600px] h-[600px] bg-[var(--accent)]/10 blur-[120px] rounded-full hidden md:block\" data-kid=\"18\"></div>\n        \n        <div class=\"badge-float absolute top-[25%] left-[8%] glass p-4 rounded-xl flex items-center gap-3 rotate-[-6deg] hidden lg:flex\" data-kid=\"19\">\n            <img src=\"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/react/react-original.svg\" class=\"w-6 h-6\" alt=\"React\" data-kid=\"20\">\n            <span class=\"text-sm font-medium\" data-kid=\"21\">React Native</span>\n        </div>\n        <div class=\"badge-float absolute bottom-[25%] right-[10%] glass p-4 rounded-xl flex items-center gap-3 rotate-[10deg] hidden lg:flex\" data-kid=\"22\">\n            <img src=\"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-original.svg\" class=\"w-6 h-6\" alt=\"TS\" data-kid=\"23\">\n            <span class=\"text-sm font-medium\" data-kid=\"24\">TypeScript</span>\n        </div>\n        <div class=\"badge-float absolute top-[30%] right-[15%] glass p-4 rounded-xl flex items-center gap-3 rotate-[15deg] hidden lg:flex\" data-kid=\"25\">\n            <img src=\"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/nextjs/nextjs-original.svg\" class=\"w-6 h-6 invert dark:invert-0\" alt=\"Next\" data-kid=\"26\">\n            <span class=\"text-sm font-medium\" data-kid=\"27\">Next.js</span>\n        </div>\n\n        <div class=\"max-w-5xl mx-auto text-center relative z-10\" data-kid=\"28\">\n            <div class=\"inline-flex items-center px-4 py-1.5 rounded-full border border-white/10 bg-white/5 text-[var(--text-secondary)] text-[10px] font-mono mb-10 uppercase tracking-[0.2em]\" id=\"hero-badge\" data-kid=\"29\">\n                Senior React & React Native Lead\n            </div>\n            <h1 class=\"text-6xl md:text-9xl font-bold tracking-tighter mb-10 leading-[0.9] text-white\" id=\"hero-title\" data-kid=\"30\">\n                Rodrigo Alexis Peralta\n            </h1>\n            <p class=\"text-lg md:text-xl text-[var(--text-secondary)] max-w-2xl mx-auto mb-14 font-normal leading-relaxed\" id=\"hero-subtitle\" data-kid=\"31\">\n                Building scalable fintech architectures and high-traffic mobile ecosystems with technical precision.\n            </p>\n            <div class=\"flex flex-col sm:flex-row items-center justify-center gap-10\" data-kid=\"32\">\n                <a href=\"#contact\" class=\"group relative px-10 py-4 bg-white text-black font-bold rounded-full overflow-hidden transition-all duration-300\" data-kid=\"33\">\n                    <span class=\"relative z-10\" data-kid=\"34\">Hire Me</span>\n                    <div class=\"absolute inset-0 bg-[var(--accent)] translate-y-full group-hover:translate-y-0 transition-transform duration-300\" data-kid=\"35\"></div>\n                </a>\n                <a href=\"#experience\" class=\"group flex items-center gap-3 text-white font-bold tracking-tight hover:text-[var(--accent)] transition-colors\" data-kid=\"36\">\n                    Explore Experience\n                    <i class=\"fas fa-arrow-right text-xs group-hover:translate-x-1 transition-transform\" data-kid=\"37\"></i>\n                </a>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-32 px-6\" id=\"about\" data-kid=\"38\">\n        <div class=\"max-w-7xl mx-auto\" data-kid=\"39\">\n            <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-8\" data-kid=\"40\">\n                \n                <div class=\"lg:col-span-8 flex flex-col justify-center reveal-up\" data-kid=\"41\">\n                    <h2 class=\"text-10xl font-bold tracking-tighter opacity-5 absolute -top-10 left-0 select-none\" data-kid=\"42\">BIO</h2>\n                    <h3 class=\"text-4xl font-bold mb-10 flex items-center gap-4\" data-kid=\"43\">\n                        <span class=\"w-8 h-8 bg-white rounded-full flex items-center justify-center text-black text-xs font-mono\" data-kid=\"44\">01</span>\n                        Strategic Development\n                    </h3>\n                    <div class=\"space-y-8 text-xl text-[var(--text-secondary)] leading-relaxed max-w-3xl\" data-kid=\"45\">\n                        <p data-kid=\"46\">\n                            With 5+ years of specialized experience, I transform complex business requirements into performant technical solutions. My focus lies at the intersection of <span class=\"text-white font-medium\" data-kid=\"47\">Fintech innovation</span> and <span class=\"text-white font-medium\" data-kid=\"48\">Aviation reliability</span>.\n                        </p>\n                        <p data-kid=\"49\">\n                            I lead teams through the complete development lifecycle, prioritizing clean architecture, type safety, and seamless UI/UX across all digital touchpoints.\n                        </p>\n                    </div>\n                    <div class=\"flex flex-wrap gap-8 mt-14 font-mono text-xs uppercase tracking-widest text-[var(--text-secondary)]\" data-kid=\"50\">\n                        <div class=\"flex items-center gap-3\" data-kid=\"51\">\n                            <span class=\"w-2 h-2 rounded-full bg-[var(--accent)]\" data-kid=\"52\"></span> Argentina Based\n                        </div>\n                        <div class=\"flex items-center gap-3\" data-kid=\"53\">\n                            <span class=\"w-2 h-2 rounded-full bg-[var(--accent)]\" data-kid=\"54\"></span> Full English Proficiency\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"lg:col-span-4 grid grid-cols-2 lg:grid-cols-1 gap-6\" data-kid=\"55\">\n                    <div class=\"bg-[var(--card)] rounded-2xl p-10 border border-white/5 reveal-up\" data-kid=\"56\">\n                        <span class=\"text-7xl font-mono font-bold text-white block mb-4\" data-kid=\"57\">5<span class=\"text-[var(--accent)]\" data-kid=\"58\">+</span></span>\n                        <span class=\"text-[10px] font-mono uppercase tracking-[0.3em] text-[var(--text-secondary)]\" data-kid=\"59\">Years Engineering</span>\n                    </div>\n                    <div class=\"bg-[var(--card)] rounded-2xl p-10 border border-white/5 reveal-up\" data-kid=\"60\">\n                        <span class=\"text-7xl font-mono font-bold text-white block mb-4\" data-kid=\"61\">6</span>\n                        <span class=\"text-[10px] font-mono uppercase tracking-[0.3em] text-[var(--text-secondary)]\" data-kid=\"62\">Sector Expertise</span>\n                    </div>\n                </div>\n\n                \n                <div class=\"lg:col-span-6 flex items-start gap-8 reveal-up pt-12 border-t border-white/5\" data-kid=\"63\">\n                    <div class=\"w-12 h-12 shrink-0 bg-white/5 text-white rounded-lg flex items-center justify-center text-xl\" data-kid=\"64\">\n                        <i class=\"fas fa-microchip\" data-kid=\"65\"></i>\n                    </div>\n                    <div data-kid=\"66\">\n                        <h4 class=\"text-xl font-bold mb-4\" data-kid=\"67\">Cross-Platform Specialist</h4>\n                        <p class=\"text-[var(--text-secondary)] leading-relaxed\" data-kid=\"68\">Mastery of React Native and Expo ecosystems to deliver near-native performance with the agility of web technologies.</p>\n                    </div>\n                </div>\n                <div class=\"lg:col-span-6 flex items-start gap-8 reveal-up pt-12 border-t border-white/5\" data-kid=\"69\">\n                    <div class=\"w-16 h-16 shrink-0 bg-[var(--accent)]/10 text-[var(--accent)] rounded-2xl flex items-center justify-center text-2xl border border-[var(--accent)]/20\" data-kid=\"70\">\n                        <i class=\"fas fa-layer-group\" data-kid=\"71\"></i>\n                    </div>\n                    <div data-kid=\"72\">\n                        <h3 class=\"text-xl font-bold mb-3\" data-kid=\"73\">Architectural Vision</h3>\n                        <p class=\"text-[var(--text-secondary)]\" data-kid=\"74\">Implementing Clean Architecture and Design Patterns to build scalable, maintainable, and testable codebases.</p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-32 px-6 bg-[var(--surface)]\" id=\"experience\" data-kid=\"75\">\n        <div class=\"max-w-7xl mx-auto\" data-kid=\"76\">\n            <div class=\"mb-32\" data-kid=\"77\">\n                <h3 class=\"text-xs font-mono uppercase tracking-[0.5em] text-[var(--accent)] mb-6\" data-kid=\"78\">Chronology</h3>\n                <h2 class=\"text-5xl md:text-7xl font-bold tracking-tighter\" data-kid=\"79\">Experience Timeline</h2>\n            </div>\n\n            <div class=\"relative max-w-6xl mx-auto\" id=\"timeline-container\" data-kid=\"80\">\n                \n                <div class=\"absolute left-4 md:left-1/2 md:transform md:-translate-x-1/2 top-0 bottom-0 w-[1px] bg-white/10\" data-kid=\"81\">\n                    <div id=\"timeline-scroll-line\" class=\"absolute top-0 left-0 w-full h-full bg-[var(--accent)] scale-y-0 origin-top\" data-kid=\"82\"></div>\n                </div>\n\n                <div class=\"space-y-40\" data-kid=\"83\">\n                    \n                    <div class=\"relative flex items-center group exp-entry\" data-kid=\"84\">\n                        <div class=\"hidden md:flex w-1/2 justify-end pr-24\" data-kid=\"85\">\n                            <span class=\"text-xs font-mono font-bold uppercase tracking-widest text-[var(--text-secondary)]\" data-kid=\"86\">Aug 2023 - Present</span>\n                        </div>\n                        <div class=\"z-20 w-3 h-3 rounded-full bg-[var(--accent)] shadow-[0_0_15px_var(--accent)] absolute left-4 md:left-1/2 md:-translate-x-1/2\" data-kid=\"87\"></div>\n                        <div class=\"w-full md:w-1/2 pl-16 md:pl-24\" data-kid=\"88\">\n                            <span class=\"md:hidden text-xs font-mono font-bold uppercase tracking-widest text-[var(--accent)] mb-4 block\" data-kid=\"89\">Aug 2023 - Present</span>\n                            <h3 class=\"text-3xl font-bold mb-4\" data-kid=\"90\">Distillery</h3>\n                            <div class=\"flex items-center gap-4 mb-6\" data-kid=\"91\">\n                                <span class=\"text-xs font-mono bg-white/5 border border-white/10 px-3 py-1 rounded\" data-kid=\"92\">Sr. Developer</span>\n                                <span class=\"text-xs font-mono text-[var(--text-secondary)]\" data-kid=\"93\">IT Services</span>\n                            </div>\n                            <p class=\"text-[var(--text-secondary)] leading-relaxed text-lg mb-8 max-w-md\" data-kid=\"94\">Orchestrating complex frontend migrations and mobile development for high-stakes enterprise partners.</p>\n                            <div class=\"flex flex-wrap gap-3\" data-kid=\"95\">\n                                <span class=\"text-[10px] font-mono border border-white/10 px-2 py-1\" data-kid=\"96\">React Native</span>\n                                <span class=\"text-[10px] font-mono border border-white/10 px-2 py-1\" data-kid=\"97\">TypeSafe Props</span>\n                            </div>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"relative flex items-center md:flex-row-reverse group exp-entry\" data-kid=\"98\">\n                        <div class=\"hidden md:flex w-1/2 justify-start pl-24\" data-kid=\"99\">\n                            <span class=\"text-xs font-mono font-bold uppercase tracking-widest text-[var(--text-secondary)]\" data-kid=\"100\">Aug 2023 - Feb 2024</span>\n                        </div>\n                        <div class=\"z-20 w-3 h-3 rounded-full bg-[var(--accent)] shadow-[0_0_15px_var(--accent)] absolute left-4 md:left-1/2 md:-translate-x-1/2\" data-kid=\"101\"></div>\n                        <div class=\"w-full md:w-1/2 pl-16 md:pr-24 md:pl-0 md:text-right\" data-kid=\"102\">\n                            <span class=\"md:hidden text-xs font-mono font-bold uppercase tracking-widest text-[var(--accent)] mb-4 block\" data-kid=\"103\">Aug 2023 - Feb 2024</span>\n                            <h3 class=\"text-3xl font-bold mb-4\" data-kid=\"104\">n1u</h3>\n                            <div class=\"flex items-center gap-4 mb-6 md:justify-end\" data-kid=\"105\">\n                                <span class=\"text-xs font-mono bg-white/5 border border-white/10 px-3 py-1 rounded\" data-kid=\"106\">Freelance Dev</span>\n                                <span class=\"text-xs font-mono text-[var(--text-secondary)]\" data-kid=\"107\">Fintech</span>\n                            </div>\n                            <p class=\"text-[var(--text-secondary)] leading-relaxed text-lg mb-8 max-w-md md:ml-auto\" data-kid=\"108\">Crafting native financial experiences with high transactional reliability and security.</p>\n                            <div class=\"flex flex-wrap gap-3 md:justify-end\" data-kid=\"109\">\n                                <span class=\"text-[10px] font-mono border border-white/10 px-2 py-1\" data-kid=\"110\">React Native</span>\n                                <span class=\"text-[10px] font-mono border border-white/10 px-2 py-1\" data-kid=\"111\">Redux Toolkit</span>\n                            </div>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"relative flex items-center group exp-entry\" data-kid=\"112\">\n                        <div class=\"hidden md:flex w-1/2 justify-end pr-24\" data-kid=\"113\">\n                            <span class=\"text-xs font-mono font-bold uppercase tracking-widest text-[var(--text-secondary)]\" data-kid=\"114\">Feb 2022 - Aug 2023</span>\n                        </div>\n                        <div class=\"z-20 w-3 h-3 rounded-full bg-[var(--accent)] absolute left-4 md:left-1/2 md:-translate-x-1/2\" data-kid=\"115\"></div>\n                        <div class=\"w-full md:w-1/2 pl-16 md:pl-24\" data-kid=\"116\">\n                            <span class=\"md:hidden text-xs font-mono font-bold uppercase tracking-widest text-[var(--accent)] mb-4 block\" data-kid=\"117\">Feb 2022 - Aug 2023</span>\n                            <h3 class=\"text-3xl font-bold mb-4\" data-kid=\"118\">Valtech</h3>\n                            <div class=\"flex items-center gap-4 mb-6\" data-kid=\"119\">\n                                <span class=\"text-xs font-mono bg-white/5 border border-white/10 px-3 py-1 rounded\" data-kid=\"120\">Lead Frontend</span>\n                                <span class=\"text-xs font-mono text-[var(--text-secondary)]\" data-kid=\"121\">IT Services</span>\n                            </div>\n                            <p class=\"text-[var(--text-secondary)] leading-relaxed text-lg mb-8 max-w-md\" data-kid=\"122\">Driving digital transformation for Fortune 500 clients using modern stack architectures.</p>\n                            <div class=\"flex flex-wrap gap-3\" data-kid=\"123\">\n                                <span class=\"text-[10px] font-mono border border-white/10 px-2 py-1\" data-kid=\"124\">Next.js</span>\n                                <span class=\"text-[10px] font-mono border border-white/10 px-2 py-1\" data-kid=\"125\">Performance Opt</span>\n                            </div>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"relative flex items-center justify-start md:justify-between flex-row-reverse group exp-entry\" data-kid=\"126\">\n                        <div class=\"hidden md:block w-[45%]\" data-kid=\"127\"></div>\n                        <div class=\"z-20 w-4 h-4 rounded-full bg-[var(--accent)] border-4 border-[var(--bg)] neon-glow absolute left-0 md:left-1/2 md:-translate-x-1/2\" data-kid=\"128\"></div>\n                        <div class=\"w-full md:w-[45%] pl-10 md:pl-12 text-left\" data-kid=\"129\">\n                            <span class=\"text-[var(--accent)] font-mono text-sm mb-2 block\" data-kid=\"130\">Jun 2021 - Apr 2022</span>\n                            <div class=\"bg-[var(--card)] p-6 rounded-2xl border border-white/5 hover:border-[var(--accent)]/30 transition-all\" data-kid=\"131\">\n                                <h3 class=\"text-2xl font-bold mb-1\" data-kid=\"132\">Plannifai</h3>\n                                <div class=\"flex items-center gap-2 mb-4\" data-kid=\"133\">\n                                    <span class=\"px-2 py-0.5 text-[10px] bg-white/5 border border-white/10 rounded-md font-bold text-[var(--text-secondary)]\" data-kid=\"134\">SAAS</span>\n                                    <span class=\"text-sm font-medium\" data-kid=\"135\">Frontend Dev</span>\n                                </div>\n                                <p class=\"text-[var(--text-secondary)] text-sm mb-4\" data-kid=\"136\">Developing intelligent planning tools for modern businesses.</p>\n                                <div class=\"flex flex-wrap gap-2\" data-kid=\"137\">\n                                    <span class=\"text-[10px] bg-white/5 px-2 py-1 rounded\" data-kid=\"138\">React</span>\n                                    <span class=\"text-[10px] bg-white/5 px-2 py-1 rounded\" data-kid=\"139\">Tailwind</span>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"relative flex items-center justify-start md:justify-between group exp-entry\" data-kid=\"140\">\n                        <div class=\"hidden md:block w-[45%]\" data-kid=\"141\"></div>\n                        <div class=\"z-20 w-4 h-4 rounded-full bg-[var(--accent)] border-4 border-[var(--bg)] neon-glow absolute left-0 md:left-1/2 md:-translate-x-1/2\" data-kid=\"142\"></div>\n                        <div class=\"w-full md:w-[45%] pl-10 md:pl-0 md:pr-12 text-left md:text-right\" data-kid=\"143\">\n                            <span class=\"text-[var(--accent)] font-mono text-sm mb-2 block\" data-kid=\"144\">2018 - 2021</span>\n                            <div class=\"bg-[var(--card)] p-6 rounded-2xl border border-white/5 hover:border-[var(--accent)]/30 transition-all\" data-kid=\"145\">\n                                <h3 class=\"text-xl font-bold mb-1\" data-kid=\"146\">Banking & Gaming</h3>\n                                <p class=\"text-[var(--text-secondary)] text-sm\" data-kid=\"147\">Roles at Banco del Sol and Etermax, building foundational skills in high-stakes environments.</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-32 overflow-hidden\" id=\"tech\" data-kid=\"148\">\n        <div class=\"max-w-7xl mx-auto px-6 mb-24 text-center\" data-kid=\"149\">\n             <h2 class=\"text-5xl md:text-7xl font-bold tracking-tighter mb-8 text-white\" data-kid=\"150\">Technical Ecosystem</h2>\n             <p class=\"text-[var(--text-secondary)] max-w-xl mx-auto text-lg leading-relaxed\" data-kid=\"151\">The specialized stack I employ to architect high-performance digital experiences.</p>\n        </div>\n        \n        <div class=\"space-y-12\" data-kid=\"152\">\n            \n            <div class=\"relative flex\" data-kid=\"153\">\n                <div class=\"animate-marquee flex items-center gap-8 py-4\" data-kid=\"154\">\n                    <div class=\"flex items-center gap-3 px-8 py-4 glass rounded-xl\" data-kid=\"155\">\n                        <img src=\"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/react/react-original.svg\" class=\"w-6 h-6\" alt=\"React\" data-kid=\"156\">\n                        <span class=\"font-mono text-sm\" data-kid=\"157\">React Native</span>\n                    </div>\n                    <div class=\"flex items-center gap-3 px-8 py-4 glass rounded-xl\" data-kid=\"158\">\n                        <img src=\"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-original.svg\" class=\"w-6 h-6\" alt=\"TS\" data-kid=\"159\">\n                        <span class=\"font-mono text-sm\" data-kid=\"160\">TypeScript</span>\n                    </div>\n                    <div class=\"flex items-center gap-3 px-8 py-4 glass rounded-xl\" data-kid=\"161\">\n                        <img src=\"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/nextjs/nextjs-original.svg\" class=\"w-6 h-6 invert dark:invert-0\" alt=\"Next\" data-kid=\"162\">\n                        <span class=\"font-mono text-sm\" data-kid=\"163\">Next.js</span>\n                    </div>\n                    <div class=\"flex items-center gap-3 px-8 py-4 glass rounded-xl\" data-kid=\"164\">\n                        <img src=\"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/nodejs/nodejs-original.svg\" class=\"w-6 h-6\" alt=\"Node\" data-kid=\"165\">\n                        <span class=\"font-mono text-sm\" data-kid=\"166\">Node.js</span>\n                    </div>\n                    <div class=\"flex items-center gap-3 px-8 py-4 glass rounded-xl\" data-kid=\"167\">\n                        <img src=\"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/graphql/graphql-plain.svg\" class=\"w-6 h-6\" alt=\"GraphQL\" data-kid=\"168\">\n                        <span class=\"font-mono text-sm\" data-kid=\"169\">GraphQL</span>\n                    </div>\n                    <div class=\"flex items-center gap-3 px-8 py-4 glass rounded-xl\" data-kid=\"170\">\n                        <img src=\"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/tailwindcss/tailwindcss-original.svg\" class=\"w-6 h-6\" alt=\"Tailwind\" data-kid=\"171\">\n                        <span class=\"font-mono text-sm\" data-kid=\"172\">Tailwind CSS</span>\n                    </div>\n                    \n                    <div class=\"flex items-center gap-3 px-8 py-4 glass rounded-xl\" data-kid=\"173\">\n                        <img src=\"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/react/react-original.svg\" class=\"w-6 h-6\" alt=\"React\" data-kid=\"174\">\n                        <span class=\"font-mono text-sm\" data-kid=\"175\">React Native</span>\n                    </div>\n                    <div class=\"flex items-center gap-3 px-8 py-4 glass rounded-xl\" data-kid=\"176\">\n                        <img src=\"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-original.svg\" class=\"w-6 h-6\" alt=\"TS\" data-kid=\"177\">\n                        <span class=\"font-mono text-sm\" data-kid=\"178\">TypeScript</span>\n                    </div>\n                    <div class=\"flex items-center gap-3 px-8 py-4 glass rounded-xl\" data-kid=\"179\">\n                        <img src=\"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/nextjs/nextjs-original.svg\" class=\"w-6 h-6 invert dark:invert-0\" alt=\"Next\" data-kid=\"180\">\n                        <span class=\"font-mono text-sm\" data-kid=\"181\">Next.js</span>\n                    </div>\n                    <div class=\"flex items-center gap-3 px-8 py-4 glass rounded-xl\" data-kid=\"182\">\n                        <img src=\"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/nodejs/nodejs-original.svg\" class=\"w-6 h-6\" alt=\"Node\" data-kid=\"183\">\n                        <span class=\"font-mono text-sm\" data-kid=\"184\">Node.js</span>\n                    </div>\n                    <div class=\"flex items-center gap-3 px-8 py-4 glass rounded-xl\" data-kid=\"185\">\n                        <img src=\"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/graphql/graphql-plain.svg\" class=\"w-6 h-6\" alt=\"GraphQL\" data-kid=\"186\">\n                        <span class=\"font-mono text-sm\" data-kid=\"187\">GraphQL</span>\n                    </div>\n                    <div class=\"flex items-center gap-3 px-8 py-4 glass rounded-xl\" data-kid=\"188\">\n                        <img src=\"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/tailwindcss/tailwindcss-original.svg\" class=\"w-6 h-6\" alt=\"Tailwind\" data-kid=\"189\">\n                        <span class=\"font-mono text-sm\" data-kid=\"190\">Tailwind CSS</span>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"relative flex\" data-kid=\"191\">\n                <div class=\"animate-marquee animate-marquee-reverse flex items-center gap-8 py-4\" data-kid=\"192\">\n                    <div class=\"flex items-center gap-3 px-8 py-4 glass rounded-xl\" data-kid=\"193\">\n                        <span class=\"font-mono text-sm\" data-kid=\"194\">Redux Toolkit</span>\n                    </div>\n                    <div class=\"flex items-center gap-3 px-8 py-4 glass rounded-xl\" data-kid=\"195\">\n                        <span class=\"font-mono text-sm\" data-kid=\"196\">Zustand</span>\n                    </div>\n                    <div class=\"flex items-center gap-3 px-8 py-4 glass rounded-xl\" data-kid=\"197\">\n                        <span class=\"font-mono text-sm\" data-kid=\"198\">React Query</span>\n                    </div>\n                    <div class=\"flex items-center gap-3 px-8 py-4 glass rounded-xl\" data-kid=\"199\">\n                        <span class=\"font-mono text-sm\" data-kid=\"200\">NestJS</span>\n                    </div>\n                    <div class=\"flex items-center gap-3 px-8 py-4 glass rounded-xl\" data-kid=\"201\">\n                        <span class=\"font-mono text-sm\" data-kid=\"202\">Jest</span>\n                    </div>\n                    <div class=\"flex items-center gap-3 px-8 py-4 glass rounded-xl\" data-kid=\"203\">\n                        <span class=\"font-mono text-sm\" data-kid=\"204\">MySQL</span>\n                    </div>\n                    <div class=\"flex items-center gap-3 px-8 py-4 glass rounded-xl\" data-kid=\"205\">\n                        <span class=\"font-mono text-sm\" data-kid=\"206\">Git</span>\n                    </div>\n                    \n                    <div class=\"flex items-center gap-3 px-8 py-4 glass rounded-xl\" data-kid=\"207\">\n                        <span class=\"font-mono text-sm\" data-kid=\"208\">Redux Toolkit</span>\n                    </div>\n                    <div class=\"flex items-center gap-3 px-8 py-4 glass rounded-xl\" data-kid=\"209\">\n                        <span class=\"font-mono text-sm\" data-kid=\"210\">Zustand</span>\n                    </div>\n                    <div class=\"flex items-center gap-3 px-8 py-4 glass rounded-xl\" data-kid=\"211\">\n                        <span class=\"font-mono text-sm\" data-kid=\"212\">React Query</span>\n                    </div>\n                    <div class=\"flex items-center gap-3 px-8 py-4 glass rounded-xl\" data-kid=\"213\">\n                        <span class=\"font-mono text-sm\" data-kid=\"214\">NestJS</span>\n                    </div>\n                    <div class=\"flex items-center gap-3 px-8 py-4 glass rounded-xl\" data-kid=\"215\">\n                        <span class=\"font-mono text-sm\" data-kid=\"216\">Jest</span>\n                    </div>\n                    <div class=\"flex items-center gap-3 px-8 py-4 glass rounded-xl\" data-kid=\"217\">\n                        <span class=\"font-mono text-sm\" data-kid=\"218\">MySQL</span>\n                    </div>\n                    <div class=\"flex items-center gap-3 px-8 py-4 glass rounded-xl\" data-kid=\"219\">\n                        <span class=\"font-mono text-sm\" data-kid=\"220\">Git</span>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-32 px-6\" id=\"contact\" data-kid=\"221\">\n        <div class=\"max-w-7xl mx-auto\" data-kid=\"222\">\n            <div class=\"bg-[var(--card)] rounded-[2.5rem] border border-white/5 overflow-hidden\" data-kid=\"223\">\n                <div class=\"grid grid-cols-1 lg:grid-cols-2\" data-kid=\"224\">\n                    <div class=\"p-12 md:p-20 bg-[var(--surface)] border-r border-white/5\" data-kid=\"225\">\n                        <h2 class=\"text-5xl md:text-6xl font-bold tracking-tighter mb-10 text-white leading-none\" data-kid=\"226\">Let's discuss the next project.</h2>\n                        <p class=\"text-xl text-[var(--text-secondary)] mb-14 leading-relaxed max-w-md\" data-kid=\"227\">\n                            Open for senior engineering roles and technical leadership opportunities within innovative frontend ecosystems.\n                        </p>\n                        \n                        <div class=\"space-y-6\" data-kid=\"228\">\n                            <div class=\"flex items-center gap-6 group\" data-kid=\"229\">\n                                <div class=\"w-12 h-12 rounded-xl glass flex items-center justify-center text-[var(--accent)] group-hover:scale-110 transition-transform\" data-kid=\"230\">\n                                    <i class=\"fas fa-envelope\" data-kid=\"231\"></i>\n                                </div>\n                                <div data-kid=\"232\">\n                                    <span class=\"block text-xs uppercase tracking-widest text-[var(--text-secondary)] font-bold\" data-kid=\"233\">Email</span>\n                                    <span class=\"text-lg font-bold\" data-kid=\"234\">rodrigo@example.com</span>\n                                </div>\n                            </div>\n                            <div class=\"flex items-center gap-6 group\" data-kid=\"235\">\n                                <div class=\"w-12 h-12 rounded-xl glass flex items-center justify-center text-[var(--accent)] group-hover:scale-110 transition-transform\" data-kid=\"236\">\n                                    <i class=\"fab fa-linkedin-in\" data-kid=\"237\"></i>\n                                </div>\n                                <div data-kid=\"238\">\n                                    <span class=\"block text-xs uppercase tracking-widest text-[var(--text-secondary)] font-bold\" data-kid=\"239\">LinkedIn</span>\n                                    <span class=\"text-lg font-bold\" data-kid=\"240\">rodrigoalexisperalta</span>\n                                </div>\n                            </div>\n                        </div>\n\n                        <div class=\"flex gap-4 mt-12\" data-kid=\"241\">\n                            <a href=\"#\" class=\"w-12 h-12 glass rounded-xl flex items-center justify-center hover:text-[var(--accent)] transition-colors\" data-kid=\"242\"><i class=\"fa-brands fa-github text-xl\" data-kid=\"243\"></i></a>\n                            <a href=\"#\" class=\"w-12 h-12 glass rounded-xl flex items-center justify-center hover:text-[var(--accent)] transition-colors\" data-kid=\"244\"><i class=\"fa-brands fa-linkedin text-xl\" data-kid=\"245\"></i></a>\n                            <a href=\"#\" class=\"w-12 h-12 glass rounded-xl flex items-center justify-center hover:text-[var(--accent)] transition-colors\" data-kid=\"246\"><i class=\"fa-brands fa-twitter text-xl\" data-kid=\"247\"></i></a>\n                        </div>\n                    </div>\n\n                    <div class=\"p-12 md:p-20\" data-kid=\"248\">\n                        <form class=\"space-y-6\" data-kid=\"249\">\n                            <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\" data-kid=\"250\">\n                                <div class=\"space-y-2\" data-kid=\"251\">\n                                    <label class=\"text-xs font-bold uppercase tracking-widest text-[var(--text-secondary)]\" data-kid=\"252\">Your Name</label>\n                                    <input type=\"text\" placeholder=\"John Doe\" class=\"w-full bg-[var(--bg)] border border-white/5 rounded-xl px-5 py-4 focus:border-[var(--accent)] outline-hidden transition-colors\" data-kid=\"253\">\n                                </div>\n                                <div class=\"space-y-2\" data-kid=\"254\">\n                                    <label class=\"text-xs font-bold uppercase tracking-widest text-[var(--text-secondary)]\" data-kid=\"255\">Email Address</label>\n                                    <input type=\"email\" placeholder=\"john@example.com\" class=\"w-full bg-[var(--bg)] border border-white/5 rounded-xl px-5 py-4 focus:border-[var(--accent)] outline-hidden transition-colors\" data-kid=\"256\">\n                                </div>\n                            </div>\n                            <div class=\"space-y-2\" data-kid=\"257\">\n                                <label class=\"text-xs font-bold uppercase tracking-widest text-[var(--text-secondary)]\" data-kid=\"258\">Message</label>\n                                <textarea rows=\"6\" placeholder=\"Tell me about your project...\" class=\"w-full bg-[var(--bg)] border border-white/5 rounded-xl px-5 py-4 focus:border-[var(--accent)] outline-hidden transition-colors\" data-kid=\"259\"></textarea>\n                            </div>\n                            <button class=\"w-full py-5 bg-[var(--accent)] text-[var(--bg)] font-bold rounded-xl hover:scale-[1.02] active:scale-100 transition-all shadow-lg shadow-[var(--accent)]/20\" data-kid=\"260\">Send Message</button>\n                        </form>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <footer class=\"py-12 border-t border-white/5 px-6\" data-kid=\"261\">\n        <div class=\"max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6\" data-kid=\"262\">\n            <div class=\"text-sm text-[var(--text-secondary)]\" data-kid=\"263\">\n                © 2025 Rodrigo Peralta · Senior React Developer\n            </div>\n            <div class=\"flex items-center gap-8 text-sm text-[var(--text-secondary)]\" data-kid=\"264\">\n                <a href=\"#\" class=\"hover:text-[var(--accent)] transition-colors\" data-kid=\"265\">Privacy Policy</a>\n                <a href=\"#\" class=\"hover:text-[var(--accent)] transition-colors\" data-kid=\"266\">Terms of Service</a>\n            </div>\n            <div class=\"text-sm font-medium\" data-kid=\"267\">\n                Built with <span class=\"text-[var(--accent)]\" data-kid=\"268\">Next.js</span> & Tailwind v4\n            </div>\n        </div>\n    </footer>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"269\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"270\"></script>\n<script type=\"module\" data-kid=\"271\">\n    import { animate as animeAnimate } from 'https://esm.sh/animejs@4';\n    import Lenis from \"https://esm.sh/lenis@1\"\n    import { animate, scroll } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n    gsap.registerPlugin(ScrollTrigger);\n\n    // Smooth Scrolling\n    const lenis = new Lenis();\n    function raf(time) {\n        lenis.raf(time);\n        requestAnimationFrame(raf);\n    }\n    requestAnimationFrame(raf);\n\n    // Theme Toggle Logic\n    const themeBtn = document.getElementById('theme-toggle');\n    const themeIcon = document.getElementById('theme-icon');\n    const root = document.documentElement;\n    let isDark = true;\n\n    themeBtn.addEventListener('click', () => {\n        isDark = !isDark;\n        root.setAttribute('data-theme', isDark ? 'dark' : 'light');\n        themeIcon.className = isDark ? 'fas fa-moon' : 'fas fa-sun';\n    });\n\n    // Cursor Spotlight\n    const glow = document.getElementById('cursor-glow');\n    window.addEventListener('mousemove', (e) => {\n        gsap.to(glow, {\n            x: e.clientX - 250,\n            y: e.clientY - 250,\n            duration: 0.8,\n            ease: 'power3.out'\n        });\n    });\n\n    // Floating Badges Animation (Anime.js v4)\n    animeAnimate('.badge-float', {\n        y: [-15, 15],\n        rotate: (el, i) => i % 2 === 0 ? 8 : -8,\n        duration: 4000,\n        alternate: true,\n        loop: true,\n        ease: 'inOutQuad'\n    });\n\n    // Scroll Batch Reveal\n    gsap.set('.reveal-up', { y: 60, opacity: 0 });\n    ScrollTrigger.batch('.reveal-up', {\n        onEnter: (batch) => gsap.to(batch, {\n            y: 0,\n            opacity: 1,\n            duration: 0.8,\n            stagger: 0.15,\n            ease: 'power4.out',\n            overwrite: true\n        }),\n        start: 'top 85%'\n    });\n\n    // Timeline Scroll Line (ScaleY approach)\n    scroll(\n        animate(\"#timeline-scroll-line\", { scaleY: [0, 1] }, { ease: \"linear\" }),\n        { target: document.querySelector(\"#timeline-container\"), offset: [\"start 50%\", \"end 50%\"] }\n    );\n\n    // Timeline Entry Fade-in\n    gsap.utils.toArray('.exp-entry').forEach((entry, i) => {\n        gsap.from(entry, {\n            scrollTrigger: {\n                trigger: entry,\n                start: 'top 80%',\n            },\n            opacity: 0,\n            x: i % 2 === 0 ? -50 : 50,\n            duration: 1,\n            ease: 'power3.out'\n        });\n    });\n\n    // Hero Text Animation\n    const heroTimeline = gsap.timeline();\n    heroTimeline\n        .from('#hero-badge', { opacity: 0, y: 20, duration: 0.6 })\n        .from('#hero-title', { opacity: 0, y: 30, duration: 0.8 }, '-=0.3')\n        .from('#hero-subtitle', { opacity: 0, y: 20, duration: 0.8 }, '-=0.5')\n        .from('.badge-float', { opacity: 0, scale: 0.5, stagger: 0.2, duration: 1, ease: 'back.out(1.7)' }, '-=0.8');\n\n    // Language Toggle (Visual feedback only for now as requested structure-ready)\n    const langBtn = document.getElementById('lang-toggle');\n    let isEn = true;\n    langBtn.addEventListener('click', () => {\n        isEn = !isEn;\n        langBtn.innerText = isEn ? 'EN | ES' : 'ES | EN';\n    });\n\n    // Navbar scroll effect\n    window.addEventListener('scroll', () => {\n        const nav = document.getElementById('navbar');\n        if (window.scrollY > 50) {\n            nav.classList.add('h-16');\n            nav.classList.remove('h-20');\n        } else {\n            nav.classList.add('h-20');\n            nav.classList.remove('h-16');\n        }\n    });\n\n</script>\n",
