      },
      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap');\n\n  :root {\n    --bg: #111111;\n    --surface: #2A3439;\n    --accent: #00FFFF;\n    --text-primary: #E5E4E2;\n    --text-secondary: rgba(229, 228, 226, 0.6);\n    --grid-color: rgba(0, 255, 255, 0.04);\n  }\n\n  .font-heading { font-family: 'Space Grotesk', sans-serif; }\n  .font-body { font-family: 'IBM Plex Sans', sans-serif; }\n  .font-mono { font-family: 'IBM Plex Mono', monospace; }\n\n  .grid-bg {\n    background-image: \n      linear-gradient(var(--grid-color) 1px, transparent 1px),\n      linear-gradient(90deg, var(--grid-color) 1px, transparent 1px);\n    background-size: 40px 40px;\n  }\n\n  .brutalist-border {\n    border: 1px solid var(--accent);\n    box-shadow: 4px 4px 0px 0px var(--accent);\n  }\n\n  /* Custom Scrollbar */\n  ::-webkit-scrollbar { width: 8px; }\n  ::-webkit-scrollbar-track { background: var(--bg); }\n  ::-webkit-scrollbar-thumb { background: var(--surface); border-radius: 4px; }\n  ::-webkit-scrollbar-thumb:hover { background: var(--accent); }\n\n  /* Animation classes */\n  .reveal { opacity: 0; transform: translateY(20px); }\n  \n  .dashed-circle {\n    background-image: url(\"data:image/svg+xml,%3csvg width='100%25' height='100%25' xmlns='http://www.w3.org/2000/svg'%3e%3crect width='100%25' height='100%25' fill='none' rx='500' ry='500' stroke='%2300FFFF' stroke-width='2' stroke-dasharray='12%2c 12' stroke-dashoffset='0' stroke-linecap='square'/%3e%3c/svg%3e\");\n    border-radius: 500px;\n    animation: rotate 60s linear infinite;\n  }\n\n  @keyframes rotate {\n    from { transform: rotate(0deg); }\n    to { transform: rotate(360deg); }\n  }\n\n  .glow-cyan {\n    text-shadow: 0 0 10px rgba(0, 255, 255, 0.4);\n  }\n\n  .brutalist-border-thick {\n    border: 3px solid var(--accent);\n    box-shadow: 8px 8px 0px 0px var(--accent);\n  }\n</style>\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"1\">\n\n<div class=\"bg-[var(--bg)] text-[var(--text-primary)] font-body selection:bg-[var(--accent)] selection:text-black\" data-kid=\"2\">\n  \n  \n  <nav class=\"fixed top-0 left-0 w-full z-50 bg-[var(--bg)]/80 backdrop-blur-md border-b border-white/5\" data-kid=\"3\">\n    <div class=\"max-w-7xl mx-auto px-6 h-20 flex items-center justify-between\" data-kid=\"4\">\n      \n      <div class=\"flex items-center gap-8\" data-kid=\"5\">\n        <a href=\"#\" class=\"font-heading font-bold text-2xl tracking-tighter group\" data-kid=\"6\">\n          <span class=\"text-[var(--accent)] group-hover:mr-1 transition-all\" data-kid=\"7\">R</span>P\n        </a>\n        <div class=\"hidden md:flex gap-6 text-sm font-mono text-[var(--text-secondary)]\" data-kid=\"8\">\n          <a href=\"#about\" class=\"hover:text-[var(--accent)] transition-colors\" data-kid=\"9\">./about</a>\n          <a href=\"#experience\" class=\"hover:text-[var(--accent)] transition-colors\" data-kid=\"10\">./experience</a>\n        </div>\n      </div>\n\n      \n      \n      \n      <div class=\"flex items-center gap-6\" data-kid=\"11\">\n        <div class=\"hidden md:flex gap-6 text-sm font-mono text-[var(--text-secondary)]\" data-kid=\"12\">\n          <a href=\"#stack\" class=\"hover:text-[var(--accent)] transition-colors\" data-kid=\"13\">./stack</a>\n          <a href=\"#contact\" class=\"hover:text-[var(--accent)] transition-colors\" data-kid=\"14\">./contact</a>\n        </div>\n        <div class=\"h-6 w-[1px] bg-white/10 mx-2\" data-kid=\"15\"></div>\n        <div class=\"flex items-center gap-4 text-xs font-mono\" data-kid=\"16\">\n          <button class=\"text-[var(--accent)] hover:opacity-80\" data-kid=\"17\">EN</button>\n          <span class=\"text-white/20\" data-kid=\"18\">|</span>\n          <button class=\"text-[var(--text-secondary)] hover:text-[var(--accent)]\" data-kid=\"19\">ES</button>\n        </div>\n        <button id=\"theme-toggle\" class=\"p-2 rounded-full border border-white/10 hover:border-[var(--accent)]/50 transition-colors\" data-kid=\"20\">\n          <i class=\"ti ti-sun text-lg\" data-kid=\"21\"></i>\n        </button>\n      </div>\n    </div>\n  </nav>\n\n  \n  <header class=\"relative min-h-screen flex items-center justify-center pt-20 px-6 overflow-x-clip grid-bg\" data-kid=\"22\">\n    <div class=\"max-w-5xl w-full reveal-hero\" data-kid=\"23\">\n      \n      <div class=\"bg-[#1a1a1a] rounded-t-lg border-t border-x border-white/10 flex items-center p-3 gap-4\" data-kid=\"24\">\n        <div class=\"flex gap-3 text-white/40 font-mono text-[10px]\" data-kid=\"25\">\n          <span class=\"hover:text-[var(--accent)] cursor-default transition-colors\" data-kid=\"26\">_</span>\n          <span class=\"hover:text-[var(--accent)] cursor-default transition-colors\" data-kid=\"27\">□</span>\n          <span class=\"hover:text-red-500 cursor-default transition-colors\" data-kid=\"28\">✕</span>\n        </div>\n        <div class=\"mx-auto text-[10px] font-mono text-white/30 tracking-[0.3em] uppercase\" data-kid=\"29\">SYSTEM_CORE // SESSION_ACTIVE</div>\n      </div>\n      <div class=\"bg-[#0c0c0c] border border-white/10 p-8 md:p-16 rounded-b-lg shadow-[0_60px_120px_rgba(0,0,0,0.8)] font-mono relative overflow-hidden\" data-kid=\"30\">\n        \n        <div class=\"absolute inset-0 pointer-events-none bg-[linear-gradient(rgba(18,16,16,0)_50%,rgba(0,0,0,0.05)_50%),linear-gradient(90deg,rgba(255,0,0,0.01),rgba(0,255,0,0.005),rgba(0,0,255,0.01))] bg-[size:100%_4px,3px_100%]\" data-kid=\"31\"></div>\n        \n        <div class=\"text-[var(--accent)] mb-10 flex items-center gap-4 text-base relative z-10\" data-kid=\"32\">\n          <span class=\"text-white/20\" data-kid=\"33\">┌──(</span><span class=\"text-[var(--accent)]\" data-kid=\"34\">rodrigo㉿workstation</span><span class=\"text-white/20\" data-kid=\"35\">)-[</span><span class=\"text-white\" data-kid=\"36\">~</span><span class=\"text-white/20\" data-kid=\"37\">]</span>\n          <div class=\"flex items-center gap-2\" data-kid=\"38\">\n            <span class=\"text-white/20\" data-kid=\"39\">└─</span><span class=\"text-[var(--accent)]\" data-kid=\"40\">$</span>\n            <span id=\"typewriter-prompt\" class=\"text-white font-bold tracking-tight\" data-kid=\"41\"></span>\n            <span class=\"w-2.5 h-6 bg-[var(--accent)] animate-[pulse_0.8s_infinite] shadow-[0_0_10px_var(--accent)]\" data-kid=\"42\"></span>\n          </div>\n        </div>\n        \n        <div id=\"hero-content\" class=\"space-y-10 relative z-10\" data-kid=\"43\">\n          <h1 class=\"text-5xl md:text-9xl font-heading font-bold tracking-tighter leading-[0.85] text-white\" data-kid=\"44\">\n            Rodrigo<br data-kid=\"45\">Peralta\n          </h1>\n          <div class=\"space-y-6\" data-kid=\"46\">\n            <h2 class=\"text-2xl md:text-4xl text-[var(--accent)] font-medium tracking-tight glow-cyan\" data-kid=\"47\">\n              Senior React & React Native Engineer\n            </h2>\n            <p class=\"text-[var(--text-secondary)] max-w-2xl text-lg md:text-xl leading-relaxed font-body border-l-2 border-[var(--accent)]/20 pl-6\" data-kid=\"48\">\n              Engineering high-fidelity digital systems for <span class=\"text-white font-mono text-sm border-b border-white/20\" data-kid=\"49\">fintech</span>, <span class=\"text-white font-mono text-sm border-b border-white/20\" data-kid=\"50\">banking</span>, and <span class=\"text-white font-mono text-sm border-b border-white/20\" data-kid=\"51\">aviation</span>.\n            </p>\n          </div>\n          \n          <div class=\"flex flex-wrap gap-6 pt-6\" data-kid=\"52\">\n            <a href=\"#contact\" class=\"group relative px-10 py-5 bg-[var(--accent)] text-black font-bold uppercase tracking-widest text-xs transition-all hover:bg-black hover:text-[var(--accent)] border border-[var(--accent)]\" data-kid=\"53\">\n              <span class=\"relative z-10\" data-kid=\"54\">./EXECUTE_HIRE_CMD</span>\n              <div class=\"absolute inset-0 bg-white/10 opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"55\"></div>\n            </a>\n            <a href=\"#experience\" class=\"px-10 py-5 border border-white/20 text-white/60 font-mono font-bold uppercase tracking-widest text-xs hover:border-[var(--accent)] hover:text-[var(--accent)] transition-all\" data-kid=\"56\">\n              ./VIEW_RECORDS\n            </a>\n          </div>\n        </div>\n      </div>\n    </div>\n  </header>\n\n  \n  <section id=\"about\" class=\"py-32 px-6 relative overflow-hidden border-t border-white/5\" data-kid=\"57\">\n    <div class=\"max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-20 items-center\" data-kid=\"58\">\n      <div class=\"reveal order-2 lg:order-1\" data-kid=\"59\">\n        <span class=\"font-mono text-[var(--accent)] mb-4 block uppercase tracking-[0.3em] text-xs font-bold\" data-kid=\"60\">// 01_PROFILE</span>\n        <h2 class=\"text-4xl md:text-6xl font-heading font-bold mb-8 tracking-tighter\" data-kid=\"61\">Peralta.init()</h2>\n        <div class=\"space-y-6 text-[var(--text-secondary)] leading-relaxed text-lg font-body\" data-kid=\"62\">\n          <p data-kid=\"63\">\n            I'm a solution-oriented Senior Developer with over 5 years of experience in the tech industry. I thrive at the intersection of complex problem solving and elegant user interface design.\n          </p>\n          <p data-kid=\"64\">\n            My journey has spanned across industries from high-stakes fintech and banking to fast-paced gaming and aviation. I specialize in building robust mobile and web applications using the React ecosystem.\n          </p>\n        </div>\n        \n        \n        <div class=\"mt-16 grid grid-cols-2 md:grid-cols-4 gap-8 items-end\" data-kid=\"65\">\n          <div class=\"space-y-1 group\" data-kid=\"66\">\n            <div class=\"text-6xl md:text-7xl font-heading font-bold text-[var(--accent)] group-hover:scale-105 transition-transform origin-bottom-left glow-cyan\" data-kid=\"67\">5+</div>\n            <div class=\"font-mono text-[10px] uppercase tracking-widest text-white/40\" data-kid=\"68\">Years_Exp</div>\n          </div>\n          <div class=\"space-y-1 group\" data-kid=\"69\">\n            <div class=\"text-4xl md:text-5xl font-heading font-bold text-[var(--accent)] group-hover:scale-105 transition-transform origin-bottom-left\" data-kid=\"70\">06</div>\n            <div class=\"font-mono text-[10px] uppercase tracking-widest text-white/40\" data-kid=\"71\">Industries</div>\n          </div>\n          <div class=\"space-y-1 group\" data-kid=\"72\">\n            <div class=\"text-5xl md:text-6xl font-heading font-bold text-[var(--accent)] group-hover:scale-105 transition-transform origin-bottom-left\" data-kid=\"73\">∞</div>\n            <div class=\"font-mono text-[10px] uppercase tracking-widest text-white/40\" data-kid=\"74\">Platforms</div>\n          </div>\n          <div class=\"space-y-1 group\" data-kid=\"75\">\n             <div class=\"text-3xl md:text-4xl font-heading font-bold text-[var(--accent)] group-hover:scale-105 transition-transform origin-bottom-left\" data-kid=\"76\">LEAD</div>\n             <div class=\"font-mono text-[10px] uppercase tracking-widest text-white/40\" data-kid=\"77\">Teams</div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"reveal flex justify-center order-1 lg:order-2\" data-kid=\"78\">\n        <div class=\"relative group\" data-kid=\"79\">\n          <div class=\"w-72 h-72 md:w-96 md:h-96 p-4 flex items-center justify-center relative\" data-kid=\"80\">\n            \n            <div class=\"absolute inset-0 border-2 border-[var(--accent)] translate-x-4 translate-y-4\" data-kid=\"81\"></div>\n            <div class=\"absolute inset-0 border-2 border-white/10\" data-kid=\"82\"></div>\n            <div class=\"w-full h-full bg-[var(--surface)] overflow-hidden relative z-10 border border-white/10\" data-kid=\"83\">\n               <img src=\"https://i.pravatar.cc/800?u=rodrigo-peralta\" alt=\"Rodrigo Peralta\" class=\"w-full h-full object-cover filter grayscale contrast-125 brightness-90 hover:grayscale-0 hover:contrast-100 hover:brightness-100 transition-all duration-700\" decoding=\"async\" loading=\"lazy\" data-kid=\"84\">\n               <div class=\"absolute inset-0 bg-[var(--accent)]/10 mix-blend-multiply group-hover:opacity-0 transition-opacity\" data-kid=\"85\"></div>\n            </div>\n          </div>\n          \n          <div class=\"absolute -top-4 -right-8 bg-[var(--accent)] px-5 py-2 text-xs font-mono text-black font-bold tracking-tighter shadow-2xl z-20\" data-kid=\"86\">\n            SR_DEVELOPER_V5.0\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"experience\" class=\"py-32 px-6 bg-[var(--bg)]\" data-kid=\"87\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"88\">\n      <div class=\"reveal flex flex-col md:flex-row items-baseline justify-between mb-20 border-b border-white/10 pb-8\" data-kid=\"89\">\n        <div class=\"space-y-2\" data-kid=\"90\">\n          <span class=\"font-mono text-[var(--accent)] text-xs font-bold uppercase tracking-widest\" data-kid=\"91\">// 02_EXPERIENCE</span>\n          <h2 class=\"text-5xl md:text-7xl font-heading font-bold tracking-tighter uppercase\" data-kid=\"92\">Activity_Log</h2>\n        </div>\n        <span class=\"font-mono text-[10px] text-white/20 uppercase tracking-[0.5em] mt-4 md:mt-0\" data-kid=\"93\">Filtered_by: Chronological_Descending</span>\n      </div>\n\n      <div class=\"space-y-0\" data-kid=\"94\">\n        \n        <div class=\"reveal grid grid-cols-12 py-12 border-b border-white/5 hover:bg-white/[0.02] group\" data-kid=\"95\">\n          <div class=\"col-span-12 md:col-span-2 font-mono text-[var(--accent)] text-sm mb-4 md:mb-0\" data-kid=\"96\">\n            2023 — PRES\n          </div>\n          <div class=\"col-span-12 md:col-span-4 pr-8\" data-kid=\"97\">\n            <h3 class=\"text-2xl font-bold mb-2 group-hover:text-[var(--accent)] transition-colors\" data-kid=\"98\">Distillery</h3>\n            <div class=\"flex items-center gap-2 mb-4\" data-kid=\"99\">\n              <span class=\"text-white/30 text-xs font-mono uppercase tracking-widest\" data-kid=\"100\">IT Services</span>\n              <span class=\"w-1 h-1 bg-white/20 rounded-full\" data-kid=\"101\"></span>\n              <span class=\"text-[var(--accent)] text-[10px] font-mono font-bold\" data-kid=\"102\">ACTIVE</span>\n            </div>\n          </div>\n          <div class=\"col-span-12 md:col-span-4 mt-2 md:mt-0\" data-kid=\"103\">\n            <div class=\"text-white/80 text-xl font-medium mb-4\" data-kid=\"104\">Senior React & React Native Developer</div>\n            <ul class=\"text-[var(--text-secondary)] text-sm space-y-2 mb-6 font-body\" data-kid=\"105\">\n              <li class=\"flex gap-2\" data-kid=\"106\"><span data-kid=\"107\">-</span> Leading cross-platform mobile initiatives</li>\n              <li class=\"flex gap-2\" data-kid=\"108\"><span data-kid=\"109\">-</span> Architecting scalable React micro-frontends</li>\n            </ul>\n            <div class=\"flex flex-wrap gap-2\" data-kid=\"110\">\n              <span class=\"text-[10px] font-mono bg-white/5 border border-white/10 px-2.5 py-1 rounded-xs uppercase\" data-kid=\"111\">React</span>\n              <span class=\"text-[10px] font-mono bg-white/5 border border-white/10 px-2.5 py-1 rounded-xs uppercase\" data-kid=\"112\">React Native</span>\n              <span class=\"text-[10px] font-mono bg-white/5 border border-white/10 px-2.5 py-1 rounded-xs uppercase\" data-kid=\"113\">TypeScript</span>\n            </div>\n          </div>\n          <div class=\"col-span-12 md:col-span-2 text-right hidden md:block opacity-10 group-hover:opacity-100 transition-opacity\" data-kid=\"114\">\n            <span class=\"text-white/40 font-mono text-[10px] tracking-widest uppercase\" data-kid=\"115\">ID: 001_DIST</span>\n          </div>\n        </div>\n\n        \n        <div class=\"reveal grid grid-cols-12 py-12 border-b border-white/5 hover:bg-white/[0.02] group\" data-kid=\"116\">\n          <div class=\"col-span-12 md:col-span-2 font-mono text-[var(--accent)] text-sm mb-4 md:mb-0\" data-kid=\"117\">\n            2023 — 2024\n          </div>\n          <div class=\"col-span-12 md:col-span-4 pr-8\" data-kid=\"118\">\n            <h3 class=\"text-2xl font-bold mb-2 group-hover:text-[var(--accent)] transition-colors\" data-kid=\"119\">n1u</h3>\n            <div class=\"text-white/30 text-xs font-mono uppercase tracking-widest mb-4\" data-kid=\"120\">Fintech (Freelance)</div>\n          </div>\n          <div class=\"col-span-12 md:col-span-4 mt-2 md:mt-0\" data-kid=\"121\">\n            <div class=\"text-white/80 text-xl font-medium mb-4\" data-kid=\"122\">React & React Native Developer</div>\n            <div class=\"flex flex-wrap gap-2\" data-kid=\"123\">\n              <span class=\"text-[10px] font-mono bg-white/5 border border-white/10 px-2.5 py-1 rounded-xs uppercase\" data-kid=\"124\">Fintech</span>\n              <span class=\"text-[10px] font-mono bg-white/5 border border-white/10 px-2.5 py-1 rounded-xs uppercase\" data-kid=\"125\">Payments</span>\n            </div>\n          </div>\n          <div class=\"col-span-12 md:col-span-2 text-right hidden md:block opacity-10 group-hover:opacity-100 transition-opacity\" data-kid=\"126\">\n            <span class=\"text-white/40 font-mono text-[10px] tracking-widest uppercase\" data-kid=\"127\">ID: 002_N1U</span>\n          </div>\n        </div>\n\n        \n        <div class=\"reveal grid grid-cols-12 py-12 border-b border-white/5 hover:bg-white/[0.02] group\" data-kid=\"128\">\n          <div class=\"col-span-12 md:co