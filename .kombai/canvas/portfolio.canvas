      "html": "\n<div id=\"root\" class=\"bg-[#1A1110] text-[#F4F0EC] font-['Chivo'] selection:bg-[#00FFFF] selection:text-[#1A1110]\" data-kid=\"0\">\n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Epilogue:wght@400;700;900&family=Chivo:wght@300;400;700&display=swap');\n\n        :root {\n            --bg: #1A1110;\n            --surface: #343434;\n            --accent: #00FFFF;\n            --text-primary: #ffffff;\n            --text-secondary: #F4F0EC;\n        }\n\n        .light-theme {\n            --bg: #F4F0EC;\n            --surface: #ffffff;\n            --accent: #008B8B; /* Slightly deeper cyan for contrast in light mode */\n            --text-primary: #1A1110;\n            --text-secondary: #343434;\n        }\n\n        body {\n            background-color: var(--bg);\n            color: var(--text-secondary);\n            transition: background-color 0.5s ease, color 0.5s ease;\n        }\n\n        .font-epilogue { font-family: 'Epilogue', sans-serif; }\n        .font-chivo { font-family: 'Chivo', sans-serif; }\n\n        .text-accent { color: var(--accent); }\n        .bg-accent { background-color: var(--accent); }\n        .border-accent { border-color: var(--accent); }\n\n        .experience-band {\n            /* Removed transition to avoid conflict with GSAP slide-in */\n        }\n\n        /* Custom scrollbar for better editorial feel */\n        ::-webkit-scrollbar { width: 6px; }\n        ::-webkit-scrollbar-track { background: var(--bg); }\n        ::-webkit-scrollbar-thumb { background: var(--surface); border-radius: 10px; }\n        ::-webkit-scrollbar-thumb:hover { background: var(--accent); }\n\n        /* Bottom accent input */\n        .bottom-accent-input {\n            background: transparent;\n            border: none;\n            border-bottom: 2px solid var(--surface);\n            padding: 1rem 0;\n            width: 100%;\n            outline: none;\n            transition: border-color 0.3s ease;\n        }\n        .bottom-accent-input:focus {\n            border-bottom-color: var(--accent);\n        }\n    </style>\n\n    \n    <nav class=\"fixed top-0 left-0 w-full z-50 mix-blend-difference px-8 py-6 flex justify-between items-center transition-transform duration-500\" id=\"navbar\" data-kid=\"2\">\n        <div class=\"flex items-center gap-12\" data-kid=\"3\">\n            <a href=\"#\" class=\"text-3xl font-black font-epilogue tracking-tighter text-white\" data-kid=\"4\">RP</a>\n            <div class=\"hidden md:flex gap-8 uppercase tracking-widest text-xs font-black text-white/80\" data-kid=\"5\">\n                <a href=\"#about\" class=\"hover:text-accent transition-colors\" data-kid=\"6\">About</a>\n                <a href=\"#experience\" class=\"hover:text-accent transition-colors\" data-kid=\"7\">Experience</a>\n                <a href=\"#tech\" class=\"hover:text-accent transition-colors\" data-kid=\"8\">Stack</a>\n                <a href=\"#contact\" class=\"hover:text-accent transition-colors\" data-kid=\"9\">Contact</a>\n            </div>\n        </div>\n        <div class=\"flex items-center gap-6\" data-kid=\"10\">\n            <button id=\"lang-toggle\" class=\"uppercase text-xs font-black tracking-widest text-white/60 hover:text-accent transition-colors\" data-kid=\"11\">EN | ES</button>\n            <button id=\"theme-toggle\" class=\"uppercase text-xs font-black tracking-widest text-white/60 hover:text-accent transition-colors\" data-kid=\"12\">Theme Toggle</button>\n            <a href=\"#contact\" class=\"hidden sm:block px-6 py-2 border-2 border-white text-white text-xs font-black uppercase tracking-[0.2em] hover:bg-white hover:text-black transition-all\" data-kid=\"13\">Hire Me</a>\n        </div>\n    </nav>\n\n    \n    <section id=\"hero\" class=\"min-h-screen flex flex-col justify-end p-8 md:p-16 pt-32 relative overflow-hidden bg-[var(--bg)]\" data-kid=\"14\">\n        \n        <div class=\"absolute -top-20 -right-20 text-[60rem] leading-none font-black text-white/[0.03] select-none pointer-events-none font-epilogue\" id=\"bg-letter\" data-kid=\"15\">\n            R\n        </div>\n        \n        <div class=\"relative z-10 max-w-7xl w-full\" data-kid=\"16\">\n            <h1 class=\"text-[var(--text-primary)] font-epilogue font-black leading-[0.9] tracking-tighter uppercase mb-16 overflow-hidden\" data-kid=\"17\">\n                <span class=\"block text-7xl md:text-[12rem] lg:text-[16rem] hero-line\" data-kid=\"18\">Rodrigo</span>\n                <span class=\"block text-7xl md:text-[12rem] lg:text-[16rem] ml-12 lg:ml-24 hero-line\" data-kid=\"19\">Alexis</span>\n                <span class=\"block text-7xl md:text-[12rem] lg:text-[16rem] text-accent hero-line\" data-kid=\"20\">Peralta</span>\n            </h1>\n            \n            <div class=\"flex flex-col md:flex-row md:items-end justify-between gap-12 hero-content\" data-kid=\"21\">\n                <div class=\"max-w-xl\" data-kid=\"22\">\n                    <p class=\"text-[var(--text-secondary)] text-xl md:text-2xl font-chivo leading-relaxed opacity-80\" data-kid=\"23\">\n                        Senior React & React Native Developer. Building seamless mobile & web experiences for fintech, aviation, and beyond.\n                    </p>\n                </div>\n                <div class=\"flex flex-wrap items-center gap-12\" data-kid=\"24\">\n                    <button class=\"px-12 py-6 bg-accent text-[var(--bg)] font-black uppercase tracking-[0.3em] text-sm hover:translate-y-[-4px] transition-transform duration-300 shadow-[0_0_30px_rgba(0,255,255,0.4)]\" data-kid=\"25\">\n                        Hire Me\n                    </button>\n                    <a href=\"#experience\" class=\"text-white font-black uppercase tracking-[0.3em] text-sm border-b-8 border-accent/30 hover:border-accent transition-all duration-300 pb-1\" data-kid=\"26\">\n                        View Career\n                    </a>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"about\" class=\"py-32 bg-[var(--bg)] relative overflow-hidden\" data-kid=\"27\">\n        <div class=\"max-w-7xl mx-auto px-8 flex flex-col lg:flex-row items-center gap-16 lg:gap-24\" data-kid=\"28\">\n            \n            <div class=\"lg:w-1/2 w-full lg:-ml-24 about-image\" data-kid=\"29\">\n                <img src=\"https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?auto=format&w=1200&q=80&fit=crop\" alt=\"Rodrigo Peralta\" class=\"w-full aspect-[4/5] object-cover grayscale hover:grayscale-0 transition-all duration-1000 shadow-[20px_20px_0px_var(--surface)]\" decoding=\"async\" loading=\"lazy\" data-kid=\"30\">\n            </div>\n            \n            \n            <div class=\"lg:w-1/2 relative about-text\" data-kid=\"31\">\n                <div class=\"absolute -top-16 -left-12 text-accent text-[12rem] opacity-10 font-serif pointer-events-none select-none\" data-kid=\"32\">“</div>\n                <h2 class=\"text-5xl md:text-7xl font-epilogue font-black text-[var(--text-primary)] mb-10 leading-[0.9] uppercase tracking-tighter\" data-kid=\"33\">\n                    Crafting <span class=\"text-accent\" data-kid=\"34\">digital</span> experiences with purpose.\n                </h2>\n                <div class=\"space-y-8 text-xl md:text-2xl text-[var(--text-secondary)]/80 font-chivo leading-relaxed max-w-xl\" data-kid=\"35\">\n                    <p data-kid=\"36\">\n                        With over <span class=\"text-accent font-black\" data-kid=\"37\">5+ years</span> of professional experience, I specialize in building high-performance applications across <span class=\"text-accent font-black\" data-kid=\"38\">6 industries</span>.\n                    </p>\n                    <p data-kid=\"39\">\n                        Based in Argentina, working globally. I bridge the gap between complex backend systems and beautiful, intuitive interfaces.\n                    </p>\n                </div>\n                \n                \n                <div class=\"mt-16 grid grid-cols-2 gap-12 border-t border-[var(--surface)] pt-10\" data-kid=\"40\">\n                    <div data-kid=\"41\">\n                        <span class=\"block text-5xl font-epilogue font-black text-accent\" data-kid=\"42\">5+</span>\n                        <span class=\"text-xs uppercase tracking-[0.3em] text-[var(--text-secondary)]/50 font-bold\" data-kid=\"43\">Years of Code</span>\n                    </div>\n                    <div data-kid=\"44\">\n                        <span class=\"block text-5xl font-epilogue font-black text-accent\" data-kid=\"45\">6</span>\n                        <span class=\"text-xs uppercase tracking-[0.3em] text-[var(--text-secondary)]/50 font-bold\" data-kid=\"46\">Key Industries</span>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"experience\" class=\"py-32 bg-[var(--bg)] overflow-hidden\" data-kid=\"47\">\n        <div class=\"max-w-7xl mx-auto px-8\" data-kid=\"48\">\n            <h2 class=\"text-8xl md:text-[12rem] font-epilogue font-black text-[var(--text-primary)]/5 uppercase mb-24 tracking-tighter leading-none select-none\" data-kid=\"49\">\n                Experience\n            </h2>\n            \n            <div class=\"relative flex flex-col space-y-[-8rem]\" data-kid=\"50\">\n                \n                <div class=\"experience-band bg-[var(--surface)] p-12 md:p-20 border-l-[12px] border-accent border-t border-white/5 shadow-2xl relative z-[40] flex flex-col md:flex-row justify-between items-start md:items-center gap-8 group\" data-kid=\"51\">\n                    <div class=\"max-w-2xl\" data-kid=\"52\">\n                        <span class=\"text-accent font-black tracking-[0.2em] uppercase text-xs mb-4 block\" data-kid=\"53\">Aug 2023 – Present</span>\n                        <h3 class=\"text-5xl md:text-8xl font-epilogue font-black text-[var(--text-primary)] leading-none uppercase tracking-tighter group-hover:translate-x-4 transition-transform duration-700 ease-out\" data-kid=\"54\">Distillery</h3>\n                        <div class=\"mt-6 flex flex-wrap gap-3\" data-kid=\"55\">\n                            <span class=\"px-3 py-1 bg-[var(--bg)] text-accent text-xs font-bold uppercase tracking-widest border border-accent/20\" data-kid=\"56\">IT Services</span>\n                            <span class=\"px-3 py-1 bg-[var(--bg)] text-white/50 text-xs font-bold uppercase tracking-widest border border-white/10\" data-kid=\"57\">Full-time</span>\n                        </div>\n                    </div>\n                    <div class=\"md:text-right\" data-kid=\"58\">\n                        <p class=\"text-3xl md:text-5xl text-[var(--text-primary)] font-black uppercase tracking-tight leading-none\" data-kid=\"59\">Senior React & React Native Developer</p>\n                        <p class=\"text-[var(--text-secondary)]/60 font-chivo mt-4 max-w-sm md:ml-auto text-lg\" data-kid=\"60\">Leading mobile development strategies and cross-platform architecture.</p>\n                    </div>\n                </div>\n\n                \n                <div class=\"experience-band bg-[#2d2d2d] p-12 md:p-20 border-l-[12px] border-accent/60 border-t border-white/5 shadow-2xl relative z-[30] ml-8 md:ml-24 flex flex-col md:flex-row justify-between items-start md:items-center gap-8 group\" data-kid=\"61\">\n                    <div class=\"max-w-2xl\" data-kid=\"62\">\n                        <span class=\"text-[var(--text-secondary)]/50 font-black tracking-[0.2em] uppercase text-xs mb-4 block\" data-kid=\"63\">Aug 2023 – Feb 2024</span>\n                        <h3 class=\"text-5xl md:text-8xl font-epilogue font-black text-[var(--text-primary)] leading-none uppercase tracking-tighter group-hover:translate-x-4 transition-transform duration-700 ease-out\" data-kid=\"64\">n1u</h3>\n                        <div class=\"mt-6 flex flex-wrap gap-3\" data-kid=\"65\">\n                            <span class=\"px-3 py-1 bg-[var(--bg)] text-accent text-xs font-bold uppercase tracking-widest border border-accent/20\" data-kid=\"66\">Fintech</span>\n                            <span class=\"px-3 py-1 bg-[var(--bg)] text-white/50 text-xs font-bold uppercase tracking-widest border border-white/10\" data-kid=\"67\">Freelance</span>\n                        </div>\n                    </div>\n                    <div class=\"md:text-right\" data-kid=\"68\">\n                        <p class=\"text-3xl md:text-5xl text-[var(--text-primary)] font-black uppercase tracking-tight leading-none\" data-kid=\"69\">React & React Native Developer</p>\n                        <p class=\"text-[var(--text-secondary)]/60 font-chivo mt-4 max-w-sm md:ml-auto text-lg\" data-kid=\"70\">Building the future of digital banking and crypto wallets in Latin America.</p>\n                    </div>\n                </div>\n\n                \n                <div class=\"experience-band bg-[var(--surface)] p-12 md:p-20 border-l-[12px] border-accent/40 border-t border-white/5 shadow-2xl relative z-[20] ml-16 md:ml-48 flex flex-col md:flex-row justify-between items-start md:items-center gap-8 group\" data-kid=\"71\">\n                    <div class=\"max-w-2xl\" data-kid=\"72\">\n                        <span class=\"text-[var(--text-secondary)]/50 font-black tracking-[0.2em] uppercase text-xs mb-4 block\" data-kid=\"73\">Feb 2022 – Aug 2023</span>\n                        <h3 class=\"text-5xl md:text-8xl font-epilogue font-black text-[var(--text-primary)] leading-none uppercase tracking-tighter group-hover:translate-x-4 transition-transform duration-700 ease-out\" data-kid=\"74\">Valtech</h3>\n                        <div class=\"mt-6 flex flex-wrap gap-3\" data-kid=\"75\">\n                            <span class=\"px-3 py-1 bg-[var(--bg)] text-accent text-xs font-bold uppercase tracking-widest border border-accent/20\" data-kid=\"76\">IT Services</span>\n                        </div>\n                    </div>\n                    <div class=\"md:text-right\" data-kid=\"77\">\n                        <p class=\"text-3xl md:text-5xl text-[var(--text-primary)] font-black uppercase tracking-tight leading-none\" data-kid=\"78\">Senior Developer</p>\n                        <p class=\"text-[var(--text-secondary)]/60 font-chivo mt-4 max-w-sm md:ml-auto text-lg\" data-kid=\"79\">Architecture-level solutions for large scale global platforms.</p>\n                    </div>\n                </div>\n\n                \n                <div class=\"experience-band bg-[#252525] py-8 px-12 md:px-20 border-l-[12px] border-accent/20 relative z-[10] ml-24 md:ml-72 flex flex-col md:flex-row justify-between items-center gap-4 text-white/40\" data-kid=\"80\">\n                    <p class=\"font-black uppercase tracking-widest text-sm\" data-kid=\"81\">Plannifai • Banco del Sol • Etermax</p>\n                    <p class=\"text-xs uppercase tracking-widest\" data-kid=\"82\">2018 — 2022</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"tech\" class=\"py-32 bg-[var(--bg)]\" data-kid=\"83\">\n        <div class=\"max-w-7xl mx-auto px-8\" data-kid=\"84\">\n            <h2 class=\"text-6xl md:text-8xl font-epilogue font-black text-[var(--text-primary)] uppercase mb-20 tracking-tighter\" data-kid=\"85\">Stack</h2>\n            \n            <div class=\"grid grid-cols-1 md:grid-cols-4 lg:grid-cols-6 gap-4 auto-rows-[280px]\" id=\"bento-grid\" data-kid=\"86\">\n                \n                <div class=\"md:col-span-2 lg:col-span-3 bg-[var(--surface)] p-10 flex flex-col justify-between group overflow-hidden relative tech-card\" data-kid=\"87\">\n                    <div class=\"absolute -right-12 -bottom-12 opacity-5 group-hover:opacity-10 transition-opacity duration-700\" data-kid=\"88\">\n                        <svg width=\"300\" height=\"300\" viewBox=\"0 0 100 100\" class=\"text-accent animate-pulse\" data-kid=\"89\">\n                            <circle cx=\"50\" cy=\"50\" r=\"45\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"0.5\" data-kid=\"90\"></circle>\n                            <rect x=\"30\" y=\"30\" width=\"40\" height=\"40\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"0.5\" transform=\"rotate(45 50 50)\" data-kid=\"91\"></rect>\n                        </svg>\n                    </div>\n                    <div data-kid=\"92\">\n                        <h3 class=\"text-3xl font-black text-accent uppercase tracking-tighter mb-6\" data-kid=\"93\">Mobile</h3>\n                        <div class=\"flex flex-wrap gap-4\" data-kid=\"94\">\n                            <span class=\"text-xl font-bold text-white\" data-kid=\"95\">React Native</span>\n                            <span class=\"text-xl font-bold text-white/40\" data-kid=\"96\">Expo</span>\n                            <span class=\"text-xl font-bold text-white/40\" data-kid=\"97\">Flutter</span>\n                        </div>\n                    </div>\n                    <div class=\"h-1 bg-accent/20 w-full rounded-full overflow-hidden\" data-kid=\"98\">\n                        <div class=\"h-full bg-accent w-[90%]\" data-kid=\"99\"></div>\n                    </div>\n                </div>\n\n                \n                <div class=\"md:col-span-2 lg:col-span-3 bg-[#2d2d2d] p-10 flex flex-col justify-between tech-card\" data-kid=\"100\">\n                    <h3 class=\"text-3xl font-black text-[var(--text-primary)] uppercase tracking-tighter\" data-kid=\"101\">Web Ecosystem</h3>\n                    <div class=\"grid grid-cols-2 gap-y-4\" data-kid=\"102\">\n                        <div class=\"flex flex-col\" data-kid=\"103\">\n                            <span class=\"text-xs uppercase text-accent font-bold mb-1\" data-kid=\"104\">Core</span>\n                            <span class=\"text-lg font-bold\" data-kid=\"105\">React.js / Next.js</span>\n                        </div>\n                        <div class=\"flex flex-col\" data-kid=\"106\">\n                            <span class=\"text-xs uppercase text-accent font-bold mb-1\" data-kid=\"107\">Styling</span>\n                            <span class=\"text-lg font-bold\" data-kid=\"108\">Tailwind / SASS</span>\n                        </div>\n                        <div class=\"flex flex-col\" data-kid=\"109\">\n                            <span class=\"text-xs uppercase text-accent font-bold mb-1\" data-kid=\"110\">Language</span>\n                            <span class=\"text-lg font-bold\" data-kid=\"111\">TypeScript / JS</span>\n                        </div>\n                        <div class=\"flex flex-col\" data-kid=\"112\">\n                            <span class=\"text-xs uppercase text-accent font-bold mb-1\" data-kid=\"113\">Testing</span>\n                            <span class=\"text-lg font-bold\" data-kid=\"114\">Jest</span>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"lg:col-span-2 bg-accent p-10 flex flex-col justify-between text-[var(--bg)] tech-card\" data-kid=\"115\">\n                    <div class=\"w-12 h-12 border-4 border-[var(--bg)] rounded-full flex items-center justify-center\" data-kid=\"116\">\n                        <div class=\"w-2 h-2 bg-[var(--bg)] rounded-full animate-ping\" data-kid=\"117\"></div>\n                    </div>\n                    <h3 class=\"text-3xl font-black uppercase tracking-tighter leading-none\" data-kid=\"118\">State<br data-kid=\"119\">Engine</h3>\n                    <p class=\"font-black uppercase tracking-widest text-xs\" data-kid=\"120\">Redux • Zustand • Query</p>\n                </div>\n\n                \n                <div class=\"md:col-span-2 lg:col-span-2 bg-[var(--surface)] p-10 flex flex-col justify-between tech-card\" data-kid=\"121\">\n                    <h3 class=\"text-3xl font-black text-white uppercase tracking-tighter\" data-kid=\"122\">Backend</h3>\n                    <div class=\"space-y-2\" data-kid=\"123\">\n                        <div class=\"flex justify-between items-center border-b border-white/10 pb-2\" data-kid=\"124\">\n                            <span class=\"font-bold\" data-kid=\"125\">NestJS</span>\n                            <span class=\"text-[10px] uppercase font-bold text-accent\" data-kid=\"126\">Node</span>\n                        </div>\n                        <div class=\"flex justify-between items-center border-b border-white/10 pb-2\" data-kid=\"127\">\n                            <span class=\"font-bold\" data-kid=\"128\">GraphQL</span>\n                            <span class=\"text-[10px] uppercase font-bold text-accent\" data-kid=\"129\">Apollo</span>\n                        </div>\n                        <div class=\"flex justify-between items-center\" data-kid=\"130\">\n                            <span class=\"font-bold\" data-kid=\"131\">MySQL</span>\n                            <span class=\"text-[10px] uppercase font-bold text-accent\" data-kid=\"132\">SQL</span>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"lg:col-span-2 bg-[#1d1d1d] border border-white/10 p-10 flex items-center justify-center tech-card group\" data-kid=\"133\">\n                    <div class=\"text-center group-hover:text-accent transition-colors\" data-kid=\"134\">\n                        <p class=\"text-xs uppercase tracking-[0.5em] font-bold mb-4\" data-kid=\"135\">Operations</p>\n                        <h3 class=\"text-3xl font-black uppercase tracking-tighter\" data-kid=\"136\">CI/CD & GIT</h3>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"contact\" class=\"py-32 bg-[var(--bg)] relative overflow-hidden\" data-kid=\"137\">\n        <div class=\"max-w-7xl mx-auto px-8 grid grid-cols-1 lg:grid-cols-2 gap-24 items-start\" data-kid=\"138\">\n            <div class=\"contact-reveal\" data-kid=\"139\">\n                <h2 class=\"text-accent font-epilogue font-black text-8xl md:text-[12rem] leading-[0.8] uppercase tracking-tighter mb-12\" data-kid=\"140\">\n                    Say<br data-kid=\"141\">Hello.\n                </h2>\n                <div class=\"space-y-6\" data-kid=\"142\">\n                    <p class=\"text-2xl font-chivo text-[var(--text-secondary)]/60\" data-kid=\"143\">Have a project in mind or want to hire me? Drop me a message.</p>\n                    <div class=\"flex flex-col gap-4\" data-kid=\"144\">\n                        <a href=\"mailto:rodrigo.peralta@example.com\" class=\"text-3xl font-black hover:text-accent transition-colors\" data-kid=\"145\">rodrigo.peralta@dev</a>\n                        <div class=\"flex gap-6 mt-4\" data-kid=\"146\">\n                            <a href=\"#\" class=\"w-12 h-12 flex items-center justify-center border border-white/20 hover:border-accent hover:text-accent transition-all\" data-kid=\"147\"><i class=\"fa-brands fa-linkedin-in text-xl\" data-kid=\"148\"></i></a>\n                            <a href=\"#\" class=\"w-12 h-12 flex items-center justify-center border border-white/20 hover:border-accent hover:text-accent transition-all\" data-kid=\"149\"><i class=\"fa-brands fa-github text-xl\" data-kid=\"150\"></i></a>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <form class=\"space-y-12 contact-form\" data-kid=\"151\">\n                <div class=\"group\" data-kid=\"152\">\n                    <label class=\"block text-xs font-black uppercase tracking-[0.3em] text-[var(--text-secondary)]/80 group-focus-within:text-accent transition-colors\" data-kid=\"153\">Your Name</label>\n                    <input type=\"text\" class=\"bottom-accent-input text-2xl font-black text-[var(--text-primary)] placeholder-white/30\" placeholder=\"John Doe\" data-kid=\"154\">\n                </div>\n                <div class=\"group\" data-kid=\"155\">\n                    <label class=\"block text-xs font-black uppercase tracking-[0.3em] text-[var(--text-secondary)]/80 group-focus-within:text-accent transition-colors\" data-kid=\"156\">Email Address</label>\n                    <input type=\"email\" class=\"bottom-accent-input text-2xl font-black text-[var(--text-primary)] placeholder-white/30\" placeholder=\"john@example.com\" data-kid=\"157\">\n                </div>\n                <div class=\"group\" data-kid=\"158\">\n                    <label class=\"block text-xs font-black uppercase tracking-[0.3em] text-[var(--text-secondary)]/80 group-focus-within:text-accent transition-colors\" data-kid=\"159\">Your Message</label>\n                    <textarea rows=\"4\" class=\"bottom-accent-input text-2xl font-black text-[var(--text-primary)] resize-none placeholder-white/30\" placeholder=\"I'd like to talk about...\" data-kid=\"160\"></textarea>\n                </div>\n                <button type=\"submit\" class=\"w-full py-6 bg-accent text-[var(--bg)] font-black uppercase tracking-[0.3em] text-sm hover:translate-y-[-4px] transition-transform duration-300 shadow-[0_10px_30px_rgba(0,255,255,0.2)]\" data-kid=\"161\">\n                    Send Message\n                </button>\n            </form>\n        </div>\n    </section>\n\n    \n    <footer class=\"py-12 border-t border-[var(--surface)] bg-[var(--bg)]\" data-kid=\"162\">\n        <div class=\"max-w-7xl mx-auto px-8 flex flex-col md:flex-row justify-between items-center gap-8\" data-kid=\"163\">\n            <div class=\"flex items-center gap-4\" data-kid=\"164\">\n                <span class=\"text-2xl font-black font-epilogue\" data-kid=\"165\">RP</span>\n                <p class=\"text-xs font-bold text-[var(--text-secondary)]/40 uppercase tracking-widest\" data-kid=\"166\">© 2025 Rodrigo Peralta • Built with Next.js</p>\n            </div>\n            <div class=\"flex gap-8 text-[10px] font-black uppercase tracking-widest text-[var(--text-secondary)]/40\" data-kid=\"167\">\n                <a href=\"#\" class=\"hover:text-accent transition-colors\" data-kid=\"168\">Privacy Policy</a>\n                <a href=\"#\" class=\"hover:text-accent transition-colors\" data-kid=\"169\">Terms of Service</a>\n                <a href=\"#\" class=\"hover:text-accent transition-colors\" data-kid=\"170\">Ar / Global</a>\n            </div>\n        </div>\n    </footer>\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"171\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"172\"></script>\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\" data-kid=\"173\">\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"174\">\n\n<script type=\"module\" data-kid=\"175\">\n    import Lenis from \"https://esm.sh/lenis@1\";\n    gsap.registerPlugin(ScrollTrigger);\n\n    // Initialize Lenis Smooth Scroll\n    const lenis = new Lenis({\n        duration: 1.2,\n        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),\n    });\n    function raf(time) {\n        lenis.raf(time);\n        requestAnimationFrame(raf);\n    }\n    requestAnimationFrame(raf);\n\n    // Hero Animations\n    const heroTl = gsap.timeline();\n    heroTl.from(\".hero-line\", {\n        y: 100,\n        opacity: 0,\n        duration: 1,\n        stagger: 0.1,\n        ease: \"power4.out\"\n    })\n    .from(\".hero-content\", {\n        y: 50,\n        opacity: 0,\n        duration: 1,\n        ease: \"power3.out\"\n    }, \"-=0.5\")\n    .from(\"#bg-letter\", {\n        opacity: 0,\n        duration: 2,\n        ease: \"power2.inOut\"\n    }, \"-=1\");\n\n    // Scroll Animations\n    gsap.from(\".about-image\", {\n        scrollTrigger: {\n            trigger: \".about-image\",\n            start: \"top 80%\",\n            end: \"bottom 20%\",\n            scrub: 1\n        },\n        x: -100,\n        opacity: 0\n    });\n\n    gsap.from(\".about-text\", {\n        scrollTrigger: {\n            trigger: \".about-text\",\n            start: \"top 80%\"\n        },\n        y: 50,\n        opacity: 0,\n        duration: 1\n    });\n\n    // Experience Staircase\n    const bands = gsap.utils.toArray(\".experience-band\");\n    bands.forEach((band, i) => {\n        gsap.from(band, {\n            scrollTrigger: {\n                trigger: band,\n                start: \"top 90%\",\n                toggleActions: \"play none none reverse\"\n            },\n            x: i % 2 === 0 ? -50 : 50,\n            opacity: 0,\n            duration: 0.8,\n            ease: \"power3.out\"\n        });\n    });\n\n    // Tech Cards\n    gsap.from(\".tech-card\", {\n        scrollTrigger: {\n            trigger: \"#bento-grid\",\n            start: \"top 80%\"\n        },\n        y: 40,\n        opacity: 0,\n        stagger: 0.1,\n        duration: 0.6,\n        ease: \"back.out(1.7)\"\n    });\n\n    // Contact Reveal\n    gsap.from(\".contact-reveal\", {\n        scrollTrigger: {\n            trigger: \"#contact\",\n            start: \"top 70%\"\n        },\n        x: -50,\n        opacity: 0,\n        duration: 1\n    });\n\n    gsap.from(\".contact-form\", {\n        scrollTrigger: {\n            trigger: \"#contact\",\n            start: \"top 70%\"\n        },\n        x: 50,\n        opacity: 0,\n        duration: 1\n    });\n\n    // Navbar Scroll Effect\n    ScrollTrigger.create({\n        start: 'top -80',\n        onUpdate: (self) => {\n            const nav = document.getElementById('navbar');\n            if (self.direction === 1) {\n                nav.style.transform = 'translateY(-100%)';\n            } else {\n                nav.style.transform = 'translateY(0)';\n                nav.style.backgroundColor = 'rgba(26, 17, 16, 0.9)';\n                nav.style.backdropFilter = 'blur(10px)';\n            }\n        }\n    });\n\n    // Theme Toggle\n    const themeBtn = document.getElementById('theme-toggle');\n    themeBtn.addEventListener('click', () => {\n        document.body.classList.toggle('light-theme');\n        const isLight = document.body.classList.contains('light-theme');\n        themeBtn.textContent = isLight ? 'Light / Dark' : 'Dark / Light';\n    });\n\n    // Lang Toggle (Mock)\n    const langBtn = document.getElementById('lang-toggle');\n    langBtn.addEventListener('click', () => {\n        const current = langBtn.textContent;\n        langBtn.textContent = current === 'EN | ES' ? 'ES | EN' : 'EN | ES';\n    });\n\n</script>\n",
