ubmit\" class=\"w-full md:w-auto px-12 py-5 bg-[var(--accent)] text-black font-bold uppercase tracking-widest text-xs hover:bg-black hover:text-[var(--accent)] border border-[var(--accent)] transition-all shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] active:shadow-none active:translate-x-1 active:translate-y-1\" data-kid=\"284\">\n            ./SEND_PAYLOAD\n          </button>\n        </form>\n\n        \n        <div class=\"mt-12 pt-12 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-8\" data-kid=\"285\">\n          <div class=\"flex gap-6\" data-kid=\"286\">\n            <a href=\"#\" class=\"text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors text-xl\" data-kid=\"287\">\n              <i class=\"ti ti-brand-github\" data-kid=\"288\"></i>\n            </a>\n            <a href=\"#\" class=\"text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors text-xl\" data-kid=\"289\">\n              <i class=\"ti ti-brand-linkedin\" data-kid=\"290\"></i>\n            </a>\n            <a href=\"#\" class=\"text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors text-xl\" data-kid=\"291\">\n              <i class=\"ti ti-mail\" data-kid=\"292\"></i>\n            </a>\n          </div>\n          <div class=\"font-mono text-[10px] text-white/20 uppercase tracking-widest\" data-kid=\"293\">\n            SECURE_ENCRYPTED_CHANNEL\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"py-12 border-t border-white/5 relative bg-black/50 overflow-hidden\" data-kid=\"294\">\n    <div class=\"max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-6\" data-kid=\"295\">\n      <div class=\"font-mono text-[10px] text-white/40 uppercase tracking-widest\" data-kid=\"296\">\n        © 2025 Rodrigo Peralta — All rights reserved\n      </div>\n      <div class=\"flex items-center gap-4\" data-kid=\"297\">\n        <span class=\"w-2 h-2 bg-green-500 rounded-full animate-pulse\" data-kid=\"298\"></span>\n        <span class=\"font-mono text-[10px] text-white/40 uppercase tracking-widest\" data-kid=\"299\">Server_Status: Operational</span>\n      </div>\n      <div class=\"font-mono text-[10px] text-white/40 uppercase tracking-widest\" data-kid=\"300\">\n        Built_with: Next.js + Tailwind + GSAP\n      </div>\n    </div>\n  </footer>\n\n  \n  <div class=\"fixed bottom-8 right-8 z-50 flex flex-col gap-2\" data-kid=\"301\">\n    <a href=\"#\" class=\"w-2 h-2 rounded-full bg-[var(--accent)] opacity-100 hover:scale-150 transition-transform\" data-kid=\"302\"></a>\n    <a href=\"#about\" class=\"w-2 h-2 rounded-full bg-white opacity-20 hover:opacity-100 transition-opacity\" data-kid=\"303\"></a>\n    <a href=\"#experience\" class=\"w-2 h-2 rounded-full bg-white opacity-20 hover:opacity-100 transition-opacity\" data-kid=\"304\"></a>\n    <a href=\"#stack\" class=\"w-2 h-2 rounded-full bg-white opacity-20 hover:opacity-100 transition-opacity\" data-kid=\"305\"></a>\n    <a href=\"#contact\" class=\"w-2 h-2 rounded-full bg-white opacity-20 hover:opacity-100 transition-opacity\" data-kid=\"306\"></a>\n  </div>\n\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"307\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"308\"></script>\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css\" data-kid=\"309\">\n\n<script type=\"module\" data-kid=\"310\">\n  import Lenis from \"https://esm.sh/lenis@1\"\n  import Snap from \"https://esm.sh/lenis@1/snap\"\n  \n  // Initialize Lenis\n  const lenis = new Lenis()\n  function raf(time) {\n    lenis.raf(time)\n    requestAnimationFrame(raf)\n  }\n  requestAnimationFrame(raf)\n\n  // GSAP Plugins\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Hero Typewriter Effect\n  const promptText = \"bash init_portfolio.sh --full-profile\";\n  const promptContainer = document.getElementById(\"typewriter-prompt\");\n  \n  let charIndex = 0;\n  function typeWriter() {\n    if (charIndex < promptText.length) {\n      promptContainer.textContent += promptText.charAt(charIndex);\n      charIndex++;\n      setTimeout(typeWriter, Math.random() * 40 + 30);\n    } else {\n      // Reveal hero content after typing\n      gsap.to(\"#hero-content\", {\n        opacity: 1,\n        y: 0,\n        duration: 1.2,\n        ease: \"power4.out\",\n        delay: 0.4\n      });\n    }\n  }\n\n  // Set initial state for hero content\n  gsap.set(\"#hero-content\", { opacity: 0, y: 50 });\n  \n  // Start typewriter on load\n  window.addEventListener('load', () => {\n    setTimeout(typeWriter, 1000);\n  });\n\n  // Section Reveal Animations\n  const reveals = document.querySelectorAll('.reveal');\n  reveals.forEach((el) => {\n    gsap.to(el, {\n      scrollTrigger: {\n        trigger: el,\n        start: \"top 85%\",\n        toggleActions: \"play none none none\"\n      },\n      opacity: 1,\n      y: 0,\n      duration: 1,\n      ease: \"power3.out\"\n    });\n  });\n\n  // Logo Animation\n  gsap.from(\".logo-text\", {\n    opacity: 0,\n    x: -20,\n    duration: 1,\n    ease: \"power4.out\"\n  });\n\n\n  // Language toggle interactivity (visual only for now)\n  const langButtons = document.querySelectorAll('button[class*=\"text-\"]');\n  langButtons.forEach(btn => {\n    btn.addEventListener('click', () => {\n       // Mock toggle\n    });\n  });\n</script>\n",
